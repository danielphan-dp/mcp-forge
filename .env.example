# Core runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
REQUEST_BODY_LIMIT=1mb
TRUST_PROXY=false
SHUTDOWN_TIMEOUT_MS=10000

# MCP transport + security
MCP_API_KEY=
ENABLE_CORS=true
MCP_ALLOWED_ORIGINS=
MCP_ALLOWED_HOSTS=
MCP_DNS_REBINDING_PROTECTION=true

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Session management
MCP_SESSION_MODE=stateful
MCP_MAX_SESSIONS=1000
MCP_SESSION_TTL_MS=3600000
MCP_SESSION_SWEEP_INTERVAL_MS=60000

# Resumability event store (memory)
MCP_EVENT_STORE=memory
MCP_EVENT_STORE_MAX_EVENTS=10000
MCP_EVENT_STORE_TTL_MS=900000
MCP_EVENT_STORE_SWEEP_INTERVAL_MS=60000

# MCP transport behavior
MCP_ENABLE_JSON_RESPONSE=false
MCP_RETRY_INTERVAL_MS=0
MCP_PROTOCOL_VERSIONS=2025-11-25,2025-03-26
MCP_REQUIRE_PROTOCOL_VERSION=false

# Metrics
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_API_KEY=
